# Supabase Configuration
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your_service_role_key

# Credential Encryption (required for storing OAuth tokens securely)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# JWT Secret: validate tokens locally (avoids timeouts). Get from Project Settings > API > JWT Secret
# SUPABASE_JWT_SECRET=your_jwt_secret

# OpenAI Configuration (optional - for AI oversight and receipt parsing)
OPENAI_API_KEY=sk-your-openai-api-key

# Perplexity AI (optional - for /ai/query market intelligence and benchmarks)
# PERPLEXITY_API_KEY=pplx-your-key

# Plaid (for bank account connection and transaction sync)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox   # sandbox | development | production

# QuickBooks Online (for QBO integration)
# QBO_CLIENT_ID=your_intuit_client_id
# QBO_CLIENT_SECRET=your_intuit_client_secret
# QBO_REDIRECT_URI=http://localhost:8000/integrations/quickbooks/callback
# QBO_ENV=sandbox   # sandbox | production

# Workday (for payroll/expense sync)
# WORKDAY_CLIENT_ID=your_workday_client_id
# WORKDAY_CLIENT_SECRET=your_workday_client_secret
# WORKDAY_TENANT_URL=https://wd2-impl-services1.workday.com/ccx/api
# WORKDAY_REDIRECT_URI=http://localhost:8000/integrations/workday/callback

# Carta (for cap table / equity data)
# CARTA_CLIENT_ID=your_carta_client_id
# CARTA_CLIENT_SECRET=your_carta_client_secret
# CARTA_REDIRECT_URI=http://localhost:8000/integrations/carta/callback

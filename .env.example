# Supabase Configuration
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your_service_role_key

# JWT Secret: validate tokens locally (avoids timeouts). Get from Project Settings > API > JWT Secret
# SUPABASE_JWT_SECRET=your_jwt_secret

# OpenAI Configuration (optional - for AI oversight and receipt parsing)
OPENAI_API_KEY=sk-your-openai-api-key

# Perplexity AI (optional - for /ai/query market intelligence and benchmarks)
# PERPLEXITY_API_KEY=pplx-your-key

# Plaid (for bank account connection and transaction sync)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox   # sandbox | development | production
